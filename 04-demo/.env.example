# RavenDB connection settings
# Copy this file to .env and fill in your values

# Your RavenDB Cloud cluster URL (e.g. https://a.free.ravendb.cloud)
# For local Docker: http://localhost:8080
RAVENDB_URL=https://your-cluster.ravendb.cloud

# Name of the database to use (will be created on first run if it doesn't exist)
RAVENDB_DATABASE=ProductsDemo

# Path to your RavenDB Cloud client certificate (.pem format)
# Required for RavenDB Cloud. Leave blank for local unsecured instances.
# To generate: RavenDB Cloud dashboard → your cluster → Manage → Client Certificate
RAVENDB_CERT_PATH=./ravendb-client.pem
